# Strapi Backend Environment Variables
# Copy this file to .env and fill in the values

# Server
HOST=0.0.0.0
PORT=1337

# Security Keys (generate unique keys for production!)
APP_KEYS=key1-change-me,key2-change-me,key3-change-me,key4-change-me
API_TOKEN_SALT=change-me-api-token-salt
ADMIN_JWT_SECRET=change-me-admin-jwt-secret
TRANSFER_TOKEN_SALT=change-me-transfer-token-salt
JWT_SECRET=change-me-jwt-secret

# Database (PostgreSQL)
DATABASE_CLIENT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=strapi_ecommerce
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi
DATABASE_SSL=false

# Cloudinary (Image hosting)
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# Email (SendGrid)
SENDGRID_API_KEY=
EMAIL_DEFAULT_FROM=noreply@yourstore.com
EMAIL_DEFAULT_REPLY_TO=support@yourstore.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000
