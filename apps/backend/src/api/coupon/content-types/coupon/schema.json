{
  "kind": "collectionType",
  "collectionName": "coupons",
  "info": {
    "singularName": "coupon",
    "pluralName": "coupons",
    "displayName": "Coupon",
    "description": "Discount coupon"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "code": {
      "type": "string",
      "unique": true,
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": ["percentage", "fixed"],
      "required": true
    },
    "value": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "minOrderAmount": {
      "type": "decimal",
      "default": 0
    },
    "maxUses": {
      "type": "integer"
    },
    "usedCount": {
      "type": "integer",
      "default": 0
    },
    "startDate": {
      "type": "datetime"
    },
    "endDate": {
      "type": "datetime"
    },
    "active": {
      "type": "boolean",
      "default": true
    }
  }
}
