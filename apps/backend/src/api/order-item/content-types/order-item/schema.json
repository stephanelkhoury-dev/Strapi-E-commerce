{
  "kind": "collectionType",
  "collectionName": "order_items",
  "info": {
    "singularName": "order-item",
    "pluralName": "order-items",
    "displayName": "Order Item",
    "description": "Line item in an order"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "quantity": {
      "type": "integer",
      "required": true,
      "min": 1
    },
    "unitPrice": {
      "type": "decimal",
      "required": true
    },
    "total": {
      "type": "decimal",
      "required": true
    },
    "productName": {
      "type": "string",
      "required": true
    },
    "productSlug": {
      "type": "string"
    },
    "variantName": {
      "type": "string"
    },
    "sku": {
      "type": "string"
    },
    "product": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product.product"
    },
    "variant": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product-variant.product-variant"
    },
    "order": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::order.order",
      "inversedBy": "items"
    }
  }
}
