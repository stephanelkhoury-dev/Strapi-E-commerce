{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "E-commerce product"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "shortDescription": {
      "type": "text",
      "maxLength": 300
    },
    "price": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "compareAtPrice": {
      "type": "decimal",
      "min": 0
    },
    "sku": {
      "type": "string",
      "unique": true
    },
    "barcode": {
      "type": "string"
    },
    "stock": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "isDigital": {
      "type": "boolean",
      "default": false
    },
    "digitalFileURL": {
      "type": "string"
    },
    "weight": {
      "type": "decimal"
    },
    "dimensions": {
      "type": "json"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "products"
    },
    "brand": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::brand.brand",
      "inversedBy": "products"
    },
    "variants": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product-variant.product-variant",
      "mappedBy": "product"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "product"
    },
    "specifications": {
      "type": "component",
      "repeatable": true,
      "component": "product.specification"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    },
    "averageRating": {
      "type": "decimal",
      "default": 0,
      "min": 0,
      "max": 5
    },
    "reviewCount": {
      "type": "integer",
      "default": 0,
      "min": 0
    }
  }
}
